<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Hurl.Settings.Views.BrowsersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctlabs="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Hurl.Settings.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Hurl.Library.Models"
    xmlns:uc="using:Hurl.Settings.Controls"
    xmlns:vm="using:Hurl.Settings.ViewModels"
    mc:Ignorable="d">

    <StackPanel MaxWidth="800" Spacing="16">
        <StackPanel Spacing="4">
            <BreadcrumbBar ItemClicked="BreadcrumbBar_ItemClicked" ItemsSource="{x:Bind BreadcrumbItems}" />
            <ListView
                AllowDrop="True"
                CanDragItems="True"
                CanReorderItems="True"
                DragItemsCompleted="ListView_DragItemsCompleted"
                ItemsSource="{x:Bind ViewModel.Browsers}"
                SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="MinHeight" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Browser">
                        <ctlabs:SettingsCard Description="{x:Bind ExePath}" Header="{x:Bind Name}">
                            <ctlabs:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8B0;" />
                            </ctlabs:SettingsCard.HeaderIcon>
                            <SplitButton x:Name="myColorButton" Click="EditBrowser_Click">
                                Edit
                                <SplitButton.Flyout>
                                    <MenuFlyout Placement="Bottom">
                                        <MenuFlyoutItem>
                                            Delete
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </SplitButton.Flyout>
                            </SplitButton>
                        </ctlabs:SettingsCard>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Other Options" />
            <StackPanel>
                <ctlabs:SettingsCard Description="Add a custom browser or app entry manually" Header="Add browser entry">
                    <ctlabs:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE710;" />
                    </ctlabs:SettingsCard.HeaderIcon>
                    <Button
                        Width="80"
                        Click="CreateBrowser_Click"
                        Style="{StaticResource AccentButtonStyle}">
                        Create
                    </Button>
                </ctlabs:SettingsCard>
                <ctlabs:SettingsCard Description="Finds and Appends newly installed browsers" Header="Refresh browsers">
                    <ctlabs:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE72C;" />
                    </ctlabs:SettingsCard.HeaderIcon>
                    <Button
                        Width="80"
                        Click="RefreshButton_Click"
                        Style="{StaticResource AccentButtonStyle}">
                        Refresh
                    </Button>
                </ctlabs:SettingsCard>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</Page>
