<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Hurl.Settings.Views.Dialogs.EditBrowserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Hurl.Library.Models"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:viewmodels="using:Hurl.Settings.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:EditBrowserPageViewModel}"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel MaxWidth="800" Spacing="12">
            <BreadcrumbBar ItemClicked="BreadcrumbBar_ItemClicked" ItemsSource="{x:Bind BreadcrumbItems}" />
            <StackPanel Spacing="16">
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Main Options" />
                    <StackPanel>
                        <toolkit:SettingsCard Header="Name">
                            <TextBox
                                x:Name="BrowserNameInput"
                                MinWidth="180"
                                MaxWidth="250"
                                PlaceholderText="Name of the Browser/App"
                                Text="{x:Bind ViewModel.Name, Mode=TwoWay}" />
                        </toolkit:SettingsCard>
                        <toolkit:SettingsCard Header="Executable Path">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button
                                    Padding="8"
                                    Click="OpenContainingExe_Click"
                                    ToolTipService.ToolTip="Open containing folder or select the file in Explorer">
                                    <FontIcon FontSize="14" Glyph="&#xE70F;" />
                                </Button>
                                <TextBox
                                    Width="300"
                                    PlaceholderText="C:\Program Files\Browser\browser.exe"
                                    Text="{x:Bind ViewModel.ExePath, Mode=TwoWay}" />
                            </StackPanel>
                        </toolkit:SettingsCard>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Advanced Options" />

                    <StackPanel>
                        <toolkit:SettingsCard Description="Rules associated to this browser will keep working" Header="Hide in Selector">
                            <CheckBox Content="Hidden" IsChecked="{x:Bind ViewModel.Hidden, Mode=TwoWay}" />
                        </toolkit:SettingsCard>
                        <toolkit:SettingsCard Description="Configure the icon shown in the selector, instead of the one from executable" Header="Custom Icon">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button
                                    Padding="8"
                                    Click="OpenContainingIcon_Click"
                                    ToolTipService.ToolTip="Open containing folder or select the file in Explorer">
                                    <FontIcon FontSize="14" Glyph="&#xE70F;" />
                                </Button>
                                <TextBox
                                    Width="280"
                                    PlaceholderText="C:\path\to\icon.ico or image"
                                    Text="{x:Bind ViewModel.CustomIconPath, Mode=TwoWay}" />
                            </StackPanel>
                        </toolkit:SettingsCard>
                        <toolkit:SettingsCard Header="Arguments">
                            <TextBox
                                Width="180"
                                MaxWidth="340"
                                PlaceholderText="--profile ..."
                                Text="{x:Bind ViewModel.LaunchArgs, Mode=TwoWay}" />
                        </toolkit:SettingsCard>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Launch Profiles" />

                    <toolkit:SettingsExpander
                        Description="Will be available in Selector, Ruleset configurations etc."
                        Header="Configured Profiles"
                        IsExpanded="True"
                        ItemsSource="{x:Bind ViewModel.AlternateLaunches}">
                        <toolkit:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE8B0;" />
                        </toolkit:SettingsExpander.HeaderIcon>
                        <toolkit:SettingsExpander.ItemTemplate>
                            <DataTemplate x:DataType="models:AlternateLaunch">
                                <toolkit:SettingsCard Description="{x:Bind LaunchArgs}" Header="{x:Bind ItemName}">
                                    <Button
                                        Click="RemoveAlternate_Click"
                                        Style="{StaticResource EllipsisButton}"
                                        ToolTipService.ToolTip="Remove alternate launch">
                                        <FontIcon Glyph="&#xE74D;" />
                                    </Button>
                                </toolkit:SettingsCard>
                            </DataTemplate>
                        </toolkit:SettingsExpander.ItemTemplate>
                    </toolkit:SettingsExpander>

                    <toolkit:SettingsCard Header="Add Launch Profile">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AltNameInput" PlaceholderText="Name" />
                            <TextBox
                                x:Name="AltArgsInput"
                                Grid.Column="1"
                                PlaceholderText="Arguments" />
                            <Button
                                Grid.Column="2"
                                Click="AddAlternate_Click"
                                Style="{StaticResource AccentButtonStyle}"
                                ToolTipService.ToolTip="Add alternate launch">
                                Add
                            </Button>
                        </Grid>
                    </toolkit:SettingsCard>

                    <StackPanel
                        Margin="0,12,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button Click="Cancel_Click" Content="Cancel" />
                        <Button
                            Click="Save_Click"
                            Content="Save"
                            Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
